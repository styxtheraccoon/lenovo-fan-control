[Unit]
Description=Lenovo P330 Fan Control Service
Documentation=https://github.com/styxtheraccoon/lenovo-fan-control
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/fan-control/fan_control_service.py
WorkingDirectory=/opt/fan-control

# Configuration
EnvironmentFile=-/etc/fan-control/fan-control.env

# Restart policy
Restart=on-failure
RestartSec=5
TimeoutStopSec=10
KillMode=mixed

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/dev /var/lib/fan-control
StateDirectory=fan-control
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fan-control

[Install]
WantedBy=multi-user.target
