# Fan Control Service Configuration
# These environment variables override config.json values

# Serial port for RP2040 (usually /dev/ttyACM0)
FAN_CONTROL_SERIAL_PORT=/dev/ttyACM0

# Temperature polling interval in seconds
FAN_CONTROL_POLL_INTERVAL=5

# API server port
FAN_CONTROL_API_PORT=9780

# API key for authentication (leave empty to disable)
FAN_CONTROL_API_KEY=CHANGE_ME_TO_A_SECURE_KEY

# Log level: DEBUG, INFO, WARNING, ERROR
FAN_CONTROL_LOG_LEVEL=INFO
